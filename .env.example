# ═══════════════════════════════════════════
#       تنظیمات محیطی ربات SFOR
# ═══════════════════════════════════════════

# توکن ربات تلگرام (از @BotFather بگیر)
TOKEN=your_bot_token_here

# آیدی عددی ادمین اصلی (از @userinfobot بگیر)
ADMIN_ID=123456789

# پسورد پنل ادمین
ADMIN_PASS=your_secure_password

# کلید API Groq — از console.groq.com بگیر (رایگانه)
# این فایل رو توی گیت‌هاب آپلود نکن!
GROQ_KEY=your_groq_api_key_here

# پورت (Render خودش تنظیم می‌کنه)
PORT=8080
